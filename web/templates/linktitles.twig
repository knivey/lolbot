{% extends 'base.twig' %}
{% import '_macros.twig' as m %}
{% block content %}
<h1 class="h3 mb-3">Linktitles</h1>
{% if error %}<div class="alert alert-danger py-2 mb-3">{{ error }}</div>{% endif %}
{% for n in networks %}
  {% set r = byNet[n.id] ?? null %}
  <div class="card mb-3"><div class="card-body">
    <h5 class="card-title">{{ n.name }}</h5>
    <form method="post" action="/linktitles/{{ n.id }}">{{ m.csrf_field() }}
      <div class="mb-3"><div class="form-check"><input class="form-check-input" type="checkbox" name="enabled" value="1" {{ r and r.enabled ? 'checked' : '' }}> <label class="form-check-label">enabled</label></div></div>
      {{ m.field('url_log_chan','url log chan', r ? r.url_log_chan : '') }}
      {{ m.field('ai_vision_model','ai model', r ? r.ai_vision_model : '') }}
      {{ m.textarea('ai_vision_prompt','ai prompt', r ? r.ai_vision_prompt : '') }}
      {{ m.field('ai_vision_reasoning_effort','reasoning effort', r ? r.ai_vision_reasoning_effort : '') }}
      {{ m.submit('Save') }}
    </form>
  </div></div>
{% endfor %}
<p class="text-body-secondary"><code>enabled</code> applies live; other fields are read per-use. Empty field = inherit/reset.</p>
{% endblock %}
